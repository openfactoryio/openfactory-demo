# OpenFactory version
OPENFACTORY_VERSION=v0.4.9

# Kafka-cluster
KAFKA_BROKER=${HOST_IP}:9092
KSQLDB_URL=http://${HOST_IP}:8088

# OpenFactory UNS schema
OPENFACTORY_UNS_SCHEMA=demo-factory/uns_schema.yml

# Fan-out layer
ASSET_ROUTER_URL=http://${HOST_IP}:8002
NATS_CLUSTER_C1=nats://${HOST_IP}:4222
ASSET_FORWARDER_LOG_LEVEL=INFO
ASSET_FORWARDER_CONCURRENCY=5

# OPCU Connector
OPCUA_CONNECTOR_COORDINATOR=http://${HOST_IP}:8000
